# EmailJS Configuration (for client-side email sending)
# Get these from https://www.emailjs.com/
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_USER=your_user_template_id
VITE_EMAILJS_TEMPLATE_ADMIN=your_admin_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
VITE_ADMIN_EMAIL=admin@futurewithmensagam.com

# Legacy Email Configuration (for server-side - can be removed if using EmailJS)
# EMAIL_SERVICE=gmail
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password
# ADMIN_EMAIL=admin@futurewithmensagam.com

# Server
PORT=5000
